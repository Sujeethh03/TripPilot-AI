# Copy to .env and fill in. Never commit .env.

# App
ENVIRONMENT=local
DEBUG=true
CORS_ORIGINS=["http://localhost:3000"]

# OpenAI (required once agents come online)
OPENAI_API_KEY=

# Data stores (required once persistence comes online)
DATABASE_URL=postgresql+asyncpg://trippilot:trippilot@localhost:5432/trippilot
REDIS_URL=redis://localhost:6379/0

# Conversation memory: "memory" (default) or "postgres" (durable across restarts)
CHECKPOINTER=memory

# Auth — set a strong random secret (>=32 bytes) in production
JWT_SECRET=dev-secret-change-me-in-production-please-32b+
# Google Sign-In: the frontend OAuth client id (audience of the ID tokens).
# Unset disables the /auth/google endpoint.
GOOGLE_CLIENT_ID=

# External APIs (wrapped by MCP servers — added as each server lands)
OPENWEATHER_KEY=          # weather MCP server (get one at openweathermap.org)
GOOGLE_MAPS_KEY=          # places + directions MCP servers (Places API + Directions API)
# currency MCP server uses Frankfurter (keyless) — nothing to configure
# ROME2RIO_KEY=           # buses MCP server (deferred)
